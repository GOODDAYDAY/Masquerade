# Masquerade Environment Variables
# Copy this file to .env and fill in your values.
# These override app_config.yaml settings.

# LLM API Key (required — set this before running)
MASQUERADE_LLM__API_KEY=sk-your-api-key-here

# LLM Model (optional — defaults to deepseek-chat)
# MASQUERADE_LLM__MODEL=deepseek-chat

# LLM API Base URL (optional)
# MASQUERADE_LLM__API_BASE=https://api.deepseek.com/v1

# Log level (optional — DEBUG, INFO, WARNING, ERROR)
# MASQUERADE_LOG_LEVEL=INFO
